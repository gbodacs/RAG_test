{
  "name": "hello-world",
  "version": "1.0.0",
  "type": "module",
  "description": "A simple TypeScript Node.js hello world project",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:css": "npx @tailwindcss/cli -i src/styles.css -o public/styles.css",
    "build:all": "npm run build:css && npm run build",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "debug": "node --inspect --loader ts-node/esm src/server.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@langchain/ollama": "^1.2.6",
    "@qdrant/js-client-rest": "^1.17.0",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "body-parser": "^1.20.2",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "ollama": "^0.6.3",
    "p-limit": "^7.3.0"
  }
}
