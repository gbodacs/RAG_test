<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload - RAG Chat Application</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4">
                <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-0">RAG Chat</h1>
                <nav class="flex flex-wrap gap-2 sm:gap-4">
                    <a href="/" class="<%= currentPage === 'home' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Home</a>
                    <a href="/upload" class="<%= currentPage === 'upload' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Upload</a>
                    <a href="/chat" class="<%= currentPage === 'chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Chat</a>
                    <a href="/advanced-chat" class="<%= currentPage === 'advanced-chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Advanced</a>
                    <a href="/logout" class="text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200 font-medium text-sm sm:text-base">Logout</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="bg-white rounded-lg shadow-md p-8">
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-gray-900 mb-2">Upload Documents</h2>
                <p class="text-gray-600">Add new text documents to expand the AI's knowledge base</p>
            </div>

            <% if (message) { %>
                <div class="mb-6 p-4 rounded-lg <%= message.includes('successfully') ? 'bg-green-50 border border-green-200 text-green-700' : 'bg-red-50 border border-red-200 text-red-700' %>">
                    <%= message %>
                </div>
            <% } %>

            <form action="/upload" method="POST" class="space-y-6">
                <div>
                    <label for="text" class="block text-sm font-medium text-gray-700 mb-2">Document Text</label>
                    <textarea id="text" name="text" rows="12" required
                              placeholder="Paste your document text here. Multiple paragraphs will be split automatically..."
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-vertical transition duration-200"></textarea>
                    <p class="mt-2 text-sm text-gray-500">Tip: Separate different documents with double line breaks</p>
                </div>
                <button type="submit" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition duration-200 transform hover:scale-105">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                    </svg>
                    Upload Document
                </button>
            </form>
        </div>
    </main>
</body>
</html>