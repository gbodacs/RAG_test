<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle || 'Chat' %> - TudatAI Demo Application</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <%- include('partials/header') %>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-lg shadow-md h-[600px] flex flex-col">
            <div class="p-6 border-b border-gray-200">
                <h2 class="text-2xl font-bold text-gray-900"><%= pageTitle || 'AI Chat' %></h2>
                <p class="text-gray-600"><%= pageDescription || 'Chat with our AI assistant' %></p>
                <% if (currentPage === 'vectorsearch') { %>
                    <div class="mt-4">
                        <a href="/upload" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition duration-200">
                            Upload Documents
                        </a>
                    </div>
                <% } %>
            </div>

            <div id="chat-container" class="flex-1 p-6 overflow-y-auto space-y-4">
                <% messages.forEach(msg => { %>
                    <div class="flex items-center space-x-3">
                        <div class="flex-1 bg-blue-50 rounded-lg p-4">
                            <p class="text-gray-900 text-right"><%= msg.user %></p>
                        </div>
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                                <span class="text-sm font-medium text-blue-600">You</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                <span class="text-sm font-medium text-green-600">AI</span>
                            </div>
                        </div>
                        <div class="flex-1 bg-green-50 rounded-lg p-4">
                            <p class="text-gray-900"><%= msg.ai %></p>
                        </div>
                    </div>
                <% }); %>
            </div>
            <div class="px-4 sm:px-6 pb-4">
                <p id="chat-status" class="text-sm text-gray-600">AI várakozik...</p>
            </div>
            <div class="p-4 sm:p-6 border-t border-gray-200">
                <form id="chat-form" class="flex space-x-2 sm:space-x-4">
                    <input type="text" id="message" name="message" required
                           placeholder="Type your message here..."
                           class="flex-1 px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm sm:text-base">
                    <button type="submit" id="send-button" class="px-3 sm:px-6 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition duration-200 text-sm sm:text-base whitespace-nowrap">
                        Send
                    </button>
                </form>
            </div>
        </div>
    </main>

    <script>
        const chatForm = document.getElementById('chat-form');
        const messageInput = document.getElementById('message');
        const sendButton = document.getElementById('send-button');
        const chatContainer = document.getElementById('chat-container');
        const chatStatus = document.getElementById('chat-status');

        let currentAIMessageElement = null;
        let currentPartialText = '';

        function updateStatus(text) {
            if (chatStatus) {
                chatStatus.textContent = text;
            }
        }

        function addUserMessage(message) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'flex items-center space-x-3';
            messageDiv.innerHTML = `
                <div class="flex-1 bg-blue-50 rounded-lg p-4">
                    <p class="text-gray-900 text-right">${message}</p>
                </div>
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-blue-600">You</span>
                    </div>
                </div>
            `;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        function createAIMessage(message) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'flex items-center space-x-3';
            messageDiv.innerHTML = `
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-green-600">AI</span>
                    </div>
                </div>
                <div class="flex-1 bg-green-50 rounded-lg p-4">
                    <p class="text-gray-900">${message}</p>
                </div>
            `;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
            return messageDiv;
        }

        function updateAIMessage(message) {
            if (!currentAIMessageElement) {
                currentAIMessageElement = createAIMessage('');
            }

            const textNode = currentAIMessageElement.querySelector('p');
            if (!textNode) return;

            if (message.length >= currentPartialText.length && message.startsWith(currentPartialText)) {
                currentPartialText = message;
            } else if (currentPartialText && message.endsWith(currentPartialText)) {
                currentPartialText = message;
            } else {
                currentPartialText += message;
            }

            textNode.textContent = currentPartialText;
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        async function streamChat(url, message) {
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'Accept': 'application/x-ndjson',
                },
                body: new URLSearchParams({ message })
            });

            if (!response.ok || !response.body) {
                const errorText = await response.text();
                throw new Error(errorText || 'Stream request failed')
            }

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                buffer += decoder.decode(value, { stream: true });

                let newlineIndex;
                while ((newlineIndex = buffer.indexOf('\n')) !== -1) {
                    const line = buffer.slice(0, newlineIndex).trim();
                    buffer = buffer.slice(newlineIndex + 1);
                    if (!line) continue;

                    let event;
                    try {
                        event = JSON.parse(line);
                    } catch (err) {
                        continue;
                    }

                    if (event.type === 'status') {
                        updateStatus(event.text || 'AI dolgozik...');
                    } else if (event.type === 'partial') {
                        updateAIMessage(event.text || '');
                    } else if (event.type === 'final') {
                        updateAIMessage(event.text || '');
                    } else if (event.type === 'error') {
                        updateAIMessage(event.text || 'Hiba történt a válasz során.');
                        updateStatus('Hiba történt');
                    }
                }
            }
        }

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const message = messageInput.value.trim();
            if (!message) return;

            addUserMessage(message);
            messageInput.value = '';
            currentAIMessageElement = null;
            currentPartialText = '';
            updateStatus('AI válasz készül...');
            sendButton.disabled = true;
            sendButton.textContent = 'Sending...';

            try {
                await streamChat('<%= streamUrl || "/chat-stream" %>', message);
                updateStatus('Válasz elkészült');
            } catch (error) {
                console.error('Error:', error);
                updateAIMessage('Sorry, there was an error processing your message.');
                updateStatus('Hiba történt');
            } finally {
                sendButton.disabled = false;
                sendButton.textContent = 'Send';
            }
        });
    </script>
</body>
</html>