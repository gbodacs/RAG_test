<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Translate - TudatAI Demo Application</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4">
                <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-0">TudatAI Demo</h1>
                <nav class="flex flex-wrap gap-2 sm:gap-4">
                    <a href="/" class="<%= currentPage === 'home' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Home</a>
                    <a href="/upload" class="<%= currentPage === 'upload' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Upload</a>
                    <a href="/chat" class="<%= currentPage === 'chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Chat</a>
                    <a href="/advanced-chat" class="<%= currentPage === 'advanced-chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Advanced</a>
                    <a href="/translate" class="<%= currentPage === 'translate' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Translate</a>
                    <a href="/logout" class="text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200 font-medium text-sm sm:text-base">Logout</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-2">AI Translator</h2>
                <p class="text-gray-600">Translate text between multiple languages using AI</p>
            </div>

            <% if (translationResult) { %>
                <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
                    <p class="text-green-800 font-medium mb-2">Translation completed!</p>
                </div>
            <% } %>

            <form id="translateForm" class="space-y-6">
                <!-- Language Selection Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Source Language -->
                    <div>
                        <label for="sourceLanguage" class="block text-sm font-medium text-gray-700 mb-2">Source Language</label>
                        <select id="sourceLanguage" name="sourceLanguage" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            <option value="english">English</option>
                            <option value="french">French</option>
                            <option value="italian">Italian</option>
                            <option value="spanish">Spanish</option>
                            <option value="german">German</option>
                            <option value="hungarian">Hungarian</option>
                        </select>
                    </div>

                    <!-- Target Language -->
                    <div>
                        <label for="targetLanguage" class="block text-sm font-medium text-gray-700 mb-2">Target Language</label>
                        <select id="targetLanguage" name="targetLanguage" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            <option value="english">English</option>
                            <option value="french" selected>French</option>
                            <option value="italian">Italian</option>
                            <option value="spanish">Spanish</option>
                            <option value="german">German</option>
                            <option value="hungarian">Hungarian</option>
                        </select>
                    </div>
                </div>

                <!-- Source Text -->
                <div>
                    <label for="sourceText" class="block text-sm font-medium text-gray-700 mb-2">Source Text</label>
                    <textarea id="sourceText" name="sourceText" rows="6" placeholder="Enter the text you want to translate..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"></textarea>
                </div>

                <!-- Target Text Display -->
                <div>
                    <label for="targetText" class="block text-sm font-medium text-gray-700 mb-2">Translated Text</label>
                    <div id="targetText" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 min-h-[150px] max-h-[400px] overflow-y-auto">
                        <% if (translatedText) { %>
                            <%= translatedText %>
                        <% } else { %>
                            <p class="text-gray-400 italic">Translation will appear here...</p>
                        <% } %>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="flex gap-3">
                    <button type="submit" id="submitBtn" class="flex-1 px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition duration-200 flex items-center justify-center">
                        <svg id="submitIcon" class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                        <span id="submitText">Translate</span>
                    </button>
                    <button type="reset" class="px-6 py-3 bg-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-400 transition duration-200">
                        Clear
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        document.getElementById('translateForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const sourceText = document.getElementById('sourceText').value;
            const sourceLanguage = document.getElementById('sourceLanguage').value;
            const targetLanguage = document.getElementById('targetLanguage').value;

            if (!sourceText.trim()) {
                alert('Please enter text to translate');
                return;
            }

            if (sourceLanguage === targetLanguage) {
                alert('Source and target languages must be different');
                return;
            }

            const submitBtn = document.getElementById('submitBtn');
            const submitText = document.getElementById('submitText');
            const submitIcon = document.getElementById('submitIcon');
            const targetTextDiv = document.getElementById('targetText');

            // Disable button and show loading state
            submitBtn.disabled = true;
            submitText.textContent = 'Translating...';
            submitIcon.style.display = 'none';
            targetTextDiv.innerHTML = '<p class="text-gray-400 italic">Translating...</p>';

            try {
                const response = await fetch('/translate', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        sourceText: sourceText,
                        sourceLanguage: sourceLanguage,
                        targetLanguage: targetLanguage
                    })
                });

                const data = await response.json();

                if (data.success) {
                    targetTextDiv.innerHTML = '<p class="text-gray-900 whitespace-pre-wrap">' + escapeHtml(data.translatedText) + '</p>';
                } else {
                    targetTextDiv.innerHTML = '<p class="text-red-600">Error: ' + escapeHtml(data.error || 'Translation failed') + '</p>';
                }
            } catch (error) {
                console.error('Translation error:', error);
                targetTextDiv.innerHTML = '<p class="text-red-600">Error: Unable to translate. Please try again.</p>';
            } finally {
                // Re-enable button and restore state
                submitBtn.disabled = false;
                submitText.textContent = 'Translate';
                submitIcon.style.display = 'inline';
            }
        });

        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }
    </script>
</body>
</html>
