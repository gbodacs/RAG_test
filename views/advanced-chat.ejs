<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Chat - TudatAI Demo Application</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4">
                <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-0">TudatAI Demo</h1>
                <nav class="flex flex-wrap gap-2 sm:gap-4">
                    <a href="/" class="<%= currentPage === 'home' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Home</a>
                    <a href="/upload" class="<%= currentPage === 'upload' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Upload</a>
                    <a href="/chat" class="<%= currentPage === 'chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Chat</a>
                    <a href="/advanced-chat" class="<%= currentPage === 'advanced-chat' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Advanced</a>
                    <a href="/translate" class="<%= currentPage === 'translate' ? 'text-blue-800 font-semibold bg-blue-50 px-2 py-1 rounded' : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200' %> font-medium text-sm sm:text-base">Translate</a>
                    <a href="/logout" class="text-gray-600 hover:text-gray-800 hover:bg-gray-50 px-2 py-1 rounded transition duration-200 font-medium text-sm sm:text-base">Logout</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-lg shadow-md h-[600px] flex flex-col">
            <div class="p-6 border-b border-gray-200">
                <h2 class="text-2xl font-bold text-gray-900">Advanced AI Chat</h2>
                <p class="text-gray-600">Enhanced AI interactions with advanced features</p>
            </div>

            <div id="chat-container" class="flex-1 p-6 overflow-y-auto space-y-4">
                <% messages.forEach(msg => { %>
                    <div class="flex items-center space-x-3">
                        <div class="flex-1 bg-purple-50 rounded-lg p-4">
                            <p class="text-gray-900 text-right"><%= msg.user %></p>
                        </div>
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                                <span class="text-sm font-medium text-purple-600">You</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
                                <span class="text-sm font-medium text-indigo-600">AI</span>
                            </div>
                        </div>
                        <div class="flex-1 bg-indigo-50 rounded-lg p-4">
                            <p class="text-gray-900"><%= msg.ai %></p>
                        </div>
                    </div>
                <% }); %>
            </div>

            <div class="p-4 sm:p-6 border-t border-gray-200">
                <form id="chat-form" class="flex space-x-2 sm:space-x-4">
                    <input type="text" id="message" name="message" required
                           placeholder="Type your advanced query here..."
                           class="flex-1 px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-sm sm:text-base">
                    <button type="submit" id="send-button" class="px-3 sm:px-6 py-2 bg-purple-600 text-white font-medium rounded-lg hover:bg-purple-700 transition duration-200 text-sm sm:text-base whitespace-nowrap">
                        Send
                    </button>
                </form>
            </div>
        </div>
    </main>

    <script>
        const chatForm = document.getElementById('chat-form');
        const messageInput = document.getElementById('message');
        const sendButton = document.getElementById('send-button');
        const chatContainer = document.getElementById('chat-container');

        // Function to add user message to chat
        function addUserMessage(message) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'flex items-center space-x-3';
            messageDiv.innerHTML = `
                <div class="flex-1 bg-purple-50 rounded-lg p-4">
                    <p class="text-gray-900 text-right">${message}</p>
                </div>
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-purple-600">You</span>
                    </div>
                </div>
            `;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Function to add AI message to chat
        function addAIMessage(message) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'flex items-center space-x-3';
            messageDiv.innerHTML = `
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-indigo-600">AI</span>
                    </div>
                </div>
                <div class="flex-1 bg-indigo-50 rounded-lg p-4">
                    <p class="text-gray-900">${message}</p>
                </div>
            `;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Function to add loading indicator
        function addLoadingIndicator() {
            const loadingDiv = document.createElement('div');
            loadingDiv.id = 'loading-indicator';
            loadingDiv.className = 'flex items-center space-x-3';
            loadingDiv.innerHTML = `
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-indigo-600">AI</span>
                    </div>
                </div>
                <div class="flex-1 bg-indigo-50 rounded-lg p-4">
                    <div class="flex items-center space-x-2">
                        <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-indigo-600"></div>
                        <p class="text-gray-600">AI is thinking...</p>
                    </div>
                </div>
            `;
            chatContainer.appendChild(loadingDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Function to remove loading indicator
        function removeLoadingIndicator() {
            const loadingDiv = document.getElementById('loading-indicator');
            if (loadingDiv) {
                loadingDiv.remove();
            }
        }

        // Handle form submission
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const message = messageInput.value.trim();
            if (!message) return;

            // Immediately show user message and clear input
            addUserMessage(message);
            messageInput.value = '';

            // Disable send button and show loading
            sendButton.disabled = true;
            sendButton.textContent = 'Sending...';
            addLoadingIndicator();

            try {
                // Send message to backend
                const response = await fetch('/advanced-chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json',
                    },
                    body: new URLSearchParams({ message: message })
                });

                if (response.ok) {
                    const data = await response.json();
                    removeLoadingIndicator();
                    addAIMessage(data.aiMessage);
                } else {
                    const errorData = await response.json().catch(() => ({ aiMessage: 'Sorry, there was an error processing your message.' }));
                    removeLoadingIndicator();
                    addAIMessage(errorData.aiMessage);
                }
            } catch (error) {
                console.error('Error:', error);
                removeLoadingIndicator();
                addAIMessage('Sorry, there was an error processing your message.');
            }

            // Re-enable send button
            sendButton.disabled = false;
            sendButton.textContent = 'Send';
        });
    </script>
</body>
</html>